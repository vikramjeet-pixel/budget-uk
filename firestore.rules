rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Validation Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isModOrAdmin() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isAuthenticated() && (role == 'moderator' || role == 'admin');
    }

    // 1. Spots
    match /spots/{spotId} {
      // Anyone can read if status is live
      allow read: if resource.data.status == 'live';
      
      // Server SDK bypasses these completely Native Firebase behaviour.
      // We grant moderator/admin roles write parity from the client interface securely here:
      allow write: if isModOrAdmin();
    }

    // 2. Submissions
    match /submissions/{submissionId} {
      allow read: if true;
      
      // Authenticated users can create with their explicit uid safely bound into submittedBy
      allow create: if isAuthenticated() 
                    && request.resource.data.submittedBy == request.auth.uid
                    && request.resource.data.status != 'live';
                    
      // Same user cannot update vote counts/status parameters directly
      allow update: if isAuthenticated() 
                    && resource.data.submittedBy == request.auth.uid
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['voteCount', 'voters', 'status']));
    }

    // 3. Users
    match /users/{userId} {
      // Users tightly bound natively to Read/Write over their singular document securely
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
      
      // Role field natively immutable from client
      allow create: if isAuthenticated() 
                    && request.auth.uid == userId
                    && request.resource.data.role == 'user';
                    
      allow update: if isAuthenticated() 
                    && request.auth.uid == userId
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    // 4. Favourites Subcollection
    match /favourites/{userId}/items/{itemId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // 5. Global Votes Table
    match /votes/{compositeId} {
      // Only permit creation (Native double-vote lock leveraging composite bounds identically)
      // Forcing the document string parameter suffix to mathematically map to Auth UUID:
      allow create: if isAuthenticated() 
                    && compositeId.matches('.*_' + request.auth.uid);
                    
      allow read: if isAuthenticated();
      allow update, delete: if false; // Flatly blocked from Client vectors.
    }
  }
}
